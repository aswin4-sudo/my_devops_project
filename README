---

## 🧪 Jenkins Pipeline (Example)

```groovy
pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git 'your-repo-url'
            }
        }

        stage('Build') {
            steps {
                sh 'docker build -t your-image .'
            }
        }

        stage('Sonar Analysis') {
            steps {
                sh 'sonar-scanner'
            }
        }

        stage('Push Image') {
            steps {
                sh 'docker push your-image'
            }
        }

        stage('Deploy') {
            steps {
                sh 'ansible-playbook -i inventory playbook.yml'
            }
        }
    }
}
```

